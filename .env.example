# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mentor

# Backend
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/mentor
LLM_PROVIDER=stub
EMBEDDING_PROVIDER=stub   # stub (default) | openai | azure_openai
LOG_LEVEL=INFO
ENVIRONMENT=dev

# Storage
BLOB_STORE=local
BLOB_STORE_ROOT=/data/blobs

# Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Frontend port (change if 3000 is already in use)
# docker-compose maps host 3001 → container 3000

# ── OpenAI — recommended for personal use (EMBEDDING_PROVIDER=openai) ────────
# Get a key at https://platform.openai.com → API Keys
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Web search (opt-in per question via the 🌐 toggle) ───────────────────────
# Default provider is "stub" (canned fake results, no key needed — great for dev/testing).
# Switch to "tavily" for real web search. Tavily free tier: 1000 searches/month.
# Sign up at https://tavily.com
#
# WEB_SEARCH_PROVIDER=stub   # stub (default) | tavily
# TAVILY_API_KEY=tvly-...    # required when WEB_SEARCH_PROVIDER=tavily
# TAVILY_SEARCH_DEPTH=basic  # basic (default, faster/cheaper) | advanced
# WEB_SEARCH_MAX_RESULTS=5

# ── Optional: Azure OpenAI (only if EMBEDDING_PROVIDER=azure_openai) ─────────
#
# AZURE_OPENAI_ENDPOINT:
#   Azure portal → your OpenAI resource → Keys and Endpoint → Endpoint
#   e.g. https://my-resource.openai.azure.com
#
# AZURE_OPENAI_API_KEY:
#   Azure portal → your OpenAI resource → Keys and Endpoint → KEY 1 or KEY 2
#
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT:
#   Azure portal → your OpenAI resource → Model deployments → deployment name
#   (the name you chose when creating the text-embedding-3-small deployment)
#
# AZURE_OPENAI_API_VERSION:
#   Stable GA version; update only when Microsoft deprecates it.

# AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-key-here
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_API_VERSION=2024-02-01
