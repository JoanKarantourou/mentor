# ── Provider selection ────────────────────────────────────────────────────────
# Choose which backend to use for each service.
# "stub" providers work out of the box with no API keys — good for local dev.

LLM_PROVIDER=stub                 # stub | anthropic
EMBEDDING_PROVIDER=stub           # stub | openai | azure_openai
WEB_SEARCH_PROVIDER=stub          # stub | tavily

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres        # Change this in any non-local deployment
POSTGRES_DB=mentor
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/mentor

# ── Storage ───────────────────────────────────────────────────────────────────
BLOB_STORE=local                  # Only "local" is implemented
BLOB_STORE_ROOT=/data/blobs       # Root path inside the backend container

# ── Frontend ──────────────────────────────────────────────────────────────────
# Change to your backend's public URL when deploying behind a reverse proxy.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# ── Operational ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
ENVIRONMENT=dev

# ── Anthropic (LLM_PROVIDER=anthropic) ───────────────────────────────────────
# Get a key at https://console.anthropic.com
#
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5     # used for standard queries
# ANTHROPIC_STRONG_MODEL=claude-sonnet-4-5     # used for regenerations

# ── OpenAI embeddings (EMBEDDING_PROVIDER=openai) ─────────────────────────────
# Recommended for personal use — one key, no cloud infrastructure.
# Get a key at https://platform.openai.com/api-keys
#
# OPENAI_API_KEY=sk-...
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Azure OpenAI embeddings (EMBEDDING_PROVIDER=azure_openai) ─────────────────
# For teams already running on Azure.
#
# AZURE_OPENAI_ENDPOINT:
#   Azure portal → your OpenAI resource → Keys and Endpoint → Endpoint
#   e.g. https://my-resource.openai.azure.com
#
# AZURE_OPENAI_API_KEY:
#   Azure portal → your OpenAI resource → Keys and Endpoint → KEY 1 or KEY 2
#
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT:
#   The deployment name you chose when provisioning the text-embedding-3-small
#   model. This is the deployment name, not the model name.
#
# AZURE_OPENAI_API_VERSION:
#   Stable GA version; update only when Microsoft deprecates it.
#
# AZURE_OPENAI_ENDPOINT=https://my-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=your-key-here
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
# AZURE_OPENAI_API_VERSION=2024-02-01

# ── Web search (WEB_SEARCH_PROVIDER=tavily) ───────────────────────────────────
# Web search is opt-in per question via the 🌐 toggle in the chat UI.
# Free tier: 1000 searches/month. Sign up at https://tavily.com
#
# TAVILY_API_KEY=tvly-...
# TAVILY_SEARCH_DEPTH=basic        # basic (default, faster) | advanced
# WEB_SEARCH_MAX_RESULTS=5

# ── Retrieval tuning ──────────────────────────────────────────────────────────
# Controls the confidence gate — when Mentor answers vs. refuses.
# Lower thresholds = more permissive (more answers, some unsupported).
# Higher thresholds = stricter (more refusals, fewer hallucinations).
#
# RETRIEVAL_TOP_K=8
# RETRIEVAL_MIN_TOP_SIMILARITY=0.25
# RETRIEVAL_MIN_AVG_SIMILARITY=0.20
# RETRIEVAL_AVG_WINDOW=5

# ── Chat ──────────────────────────────────────────────────────────────────────
# CHAT_MAX_CONTEXT_CHUNKS=8        # chunks passed to the LLM as context
# CHAT_MAX_OUTPUT_TOKENS=2048

# ── Chunking ──────────────────────────────────────────────────────────────────
# Changing these after ingestion requires re-embedding (POST /admin/reindex).
#
# CHUNK_TARGET_TOKENS=512
# CHUNK_OVERLAP_TOKENS=64
# EMBEDDING_BATCH_SIZE=50
# EMBEDDING_MAX_RETRIES=5

# ── Upload ────────────────────────────────────────────────────────────────────
# MAX_UPLOAD_SIZE_BYTES=52428800   # 50 MB default

# ── Curation — memory extraction ─────────────────────────────────────────────
# Memory extraction summarises long conversations into saved notes.
#
# MEMORY_EXTRACTION_MIN_MESSAGES=12
# MEMORY_EXTRACTION_TOPIC_SHIFT_THRESHOLD=0.5
# MEMORY_EXTRACTION_SESSION_BREAK_MINUTES=30

# ── Curation — duplicate detection ───────────────────────────────────────────
# DUPLICATE_DETECTION_ENABLED=true
# DUPLICATE_NEAR_THRESHOLD=0.92
# DUPLICATE_MATCH_RATIO=0.5

# ── Curation — gap analysis ───────────────────────────────────────────────────
# Characterises what's missing when a query returns a low-confidence refusal.
# Disable to reduce LLM calls on refusals.
#
# GAP_ANALYSIS_ENABLED=true
